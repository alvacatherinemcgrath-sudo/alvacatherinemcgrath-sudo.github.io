<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Stacks — Book & Media Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0b0d;--sb:#0d0e10;--s1:#141618;--s2:#1a1c1e;--s3:#212326;--s4:#282b2e;
  --bd:rgba(255,255,255,0.055);--bd2:rgba(255,255,255,0.11);--bd3:rgba(255,255,255,0.18);
  --tx:#e8e2d8;--tx2:#a09c95;--tx3:#5c5a56;
  --gold:#c8a24a;--gold-d:rgba(200,162,74,0.14);
  --blue:#4a8cc4;--blue-d:rgba(74,140,196,0.13);
  --grn:#4da06e;--grn-d:rgba(77,160,110,0.13);
  --red:#b84f4f;--red-d:rgba(184,79,79,0.13);
  --pur:#7a68c0;--pur-d:rgba(122,104,192,0.13);
  --teal:#3d9b96;--teal-d:rgba(61,155,150,0.13);
  --pink:#c06890;--pink-d:rgba(192,104,144,0.13);
  --r:7px;--rl:12px;--rxl:16px;
  --f:'DM Sans',sans-serif;--fd:'Playfair Display',serif;--fm:'DM Mono',monospace;
  --sw:220px;
}
body.light{
  --bg:#f5f2ed;--sb:#ede9e2;--s1:#ffffff;--s2:#f0ece5;--s3:#e5e1da;--s4:#dbd7d0;
  --bd:rgba(0,0,0,0.07);--bd2:rgba(0,0,0,0.12);--bd3:rgba(0,0,0,0.18);
  --tx:#1a1814;--tx2:#5a5650;--tx3:#9a9690;
}
body{font-family:var(--f);background:var(--bg);color:var(--tx);min-height:100vh;font-size:15px;line-height:1.6;overflow-x:hidden;transition:background .2s,color .2s}
.shell{display:flex;min-height:100vh}

/* ─── SIDEBAR ─── */
.sb{width:var(--sw);flex-shrink:0;background:var(--sb);border-right:.5px solid var(--bd);position:fixed;top:0;left:0;height:100vh;display:flex;flex-direction:column;z-index:30;overflow-y:auto}
.sb-logo{padding:18px 16px 14px;border-bottom:.5px solid var(--bd);display:flex;align-items:center;gap:10px}
.sb-logo-mark{width:30px;height:30px;background:var(--gold);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.sb-logo h1{font-family:var(--fd);font-size:17px;font-weight:400;color:var(--tx)}
.sb-nav{padding:8px 6px;flex:1}
.si{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:var(--r);cursor:pointer;font-size:12.5px;font-weight:500;color:var(--tx2);border:none;background:none;width:100%;text-align:left;font-family:var(--f);transition:all .13s}
.si:hover{color:var(--tx);background:rgba(128,128,128,0.08)}
.si.on{color:var(--tx);background:rgba(128,128,128,0.1)}
.si.on.dash{color:var(--gold)}
.si.on.browse{color:var(--blue)}
.si.on.col,.si.on.col-sub{color:var(--grn)}
.si.on.wish,.si.on.wish-sub{color:var(--pur)}
.si-ico{font-size:14px;width:16px;text-align:center;flex-shrink:0}
.si-badge{margin-left:auto;font-size:9px;background:rgba(128,128,128,0.1);color:var(--tx3);padding:1px 6px;border-radius:999px}
.sb-grp{border-top:.5px solid var(--bd);margin-top:4px;padding-top:4px}
.sb-grp-hd{display:flex;align-items:center;justify-content:space-between;padding:7px 10px 5px;cursor:pointer;font-size:9px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.12em;user-select:none}
.sb-arr{font-size:9px;transition:transform .2s}
.sb-grp.op .sb-arr{transform:rotate(90deg)}
.sb-kids{overflow:hidden;max-height:0;transition:max-height .22s ease}
.sb-grp.op .sb-kids{max-height:400px}
.sb-user{padding:12px 14px;border-top:.5px solid var(--bd);display:flex;align-items:center;gap:10px;cursor:pointer;transition:background .13s}
.sb-user:hover{background:rgba(128,128,128,0.05)}
.sb-avatar{width:32px;height:32px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:14px;color:#0a0b0d;flex-shrink:0;overflow:hidden}
.sb-avatar img{width:100%;height:100%;object-fit:cover}
.sb-uinfo{flex:1;min-width:0}
.sb-uname{font-size:12px;font-weight:600;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sb-urole{font-size:9px;color:var(--tx3)}
.sb-settings-ico{font-size:14px;color:var(--tx3);transition:color .13s}
.sb-user:hover .sb-settings-ico{color:var(--tx)}

/* ─── MAIN ─── */
.main{margin-left:var(--sw);flex:1;min-width:0;display:flex;flex-direction:column}
.topbar{position:sticky;top:0;z-index:20;background:rgba(10,11,13,0.93);backdrop-filter:blur(16px);border-bottom:.5px solid var(--bd);height:50px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;gap:12px}
body.light .topbar{background:rgba(245,242,237,0.93)}
.topbar h2{font-family:var(--fd);font-size:17px;font-weight:400;color:var(--tx);font-style:italic}
.btn-primary{display:flex;align-items:center;gap:5px;padding:7px 15px;font-size:12px;font-weight:600;font-family:var(--f);background:var(--gold);color:#0a0b0d;border:none;border-radius:var(--r);cursor:pointer;transition:opacity .13s;white-space:nowrap}
.btn-primary:hover{opacity:.82}
.btn-ghost{padding:7px 13px;font-size:12px;font-weight:500;font-family:var(--f);background:transparent;color:var(--tx2);border:.5px solid var(--bd2);border-radius:var(--r);cursor:pointer;transition:all .13s}
.btn-ghost:hover{color:var(--tx);border-color:var(--bd3)}
.content{padding:20px 24px 80px;flex:1}
.view{display:none}
.view.on{display:block;animation:fu .16s ease both}
@keyframes fu{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

/* ─── AUTH OVERLAY ─── */
.auth-ov{position:fixed;inset:0;background:var(--bg);z-index:100;display:flex;align-items:center;justify-content:center;animation:fi .2s ease}
.auth-box{background:var(--s1);border:.5px solid var(--bd2);border-radius:var(--rxl);padding:36px;width:380px;max-width:calc(100vw - 24px)}
.auth-logo{display:flex;align-items:center;gap:10px;margin-bottom:28px}
.auth-logo .lm{width:36px;height:36px;background:var(--gold);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
.auth-logo h1{font-family:var(--fd);font-size:22px;font-weight:400}
.auth-tabs{display:flex;gap:4px;background:var(--s2);padding:4px;border-radius:var(--r);margin-bottom:22px}
.auth-tab{flex:1;padding:8px;font-size:12px;font-weight:600;font-family:var(--f);background:transparent;color:var(--tx3);border:none;border-radius:5px;cursor:pointer;transition:all .15s;text-align:center}
.auth-tab.on{background:var(--s1);color:var(--tx);box-shadow:0 1px 4px rgba(0,0,0,.2)}
.auth-field{margin-bottom:14px}
.auth-field label{display:block;font-size:10px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px}
.auth-field input{width:100%;background:var(--s2);border:.5px solid var(--bd2);border-radius:var(--r);color:var(--tx);font-family:var(--f);font-size:13px;padding:9px 12px;outline:none;transition:border-color .14s}
.auth-field input:focus{border-color:var(--gold)}
.auth-btn{width:100%;padding:11px;font-size:13px;font-weight:600;font-family:var(--f);background:var(--gold);color:#0a0b0d;border:none;border-radius:var(--r);cursor:pointer;margin-top:6px;transition:opacity .13s}
.auth-btn:hover{opacity:.85}
.auth-err{font-size:11px;color:var(--red);margin-top:8px;text-align:center;min-height:16px}
.auth-skip{text-align:center;margin-top:14px;font-size:11px;color:var(--tx3);cursor:pointer;transition:color .13s}
.auth-skip:hover{color:var(--tx2)}

/* ─── DASHBOARD ─── */
.dash-hero{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rxl);padding:22px 26px;margin-bottom:18px}
.dash-total-lbl{font-size:10px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:3px}
.dash-total-val{font-family:var(--fd);font-size:40px;font-weight:400;color:var(--gold);line-height:1}
.dash-total-sub{font-size:11px;color:var(--tx3);margin-top:3px;margin-bottom:16px}
.dash-cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px}
.dash-cat{background:var(--s2);border:.5px solid var(--bd);border-radius:var(--rl);padding:12px}
.dash-cat-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--tx3);margin-bottom:5px}
.dash-cat-val{font-family:var(--fd);font-size:20px;line-height:1;margin-bottom:2px}
.dash-cat-ct{font-size:10px;color:var(--tx3)}
.dash-cat.books .dash-cat-val{color:var(--blue)}
.dash-cat.movies .dash-cat-val{color:var(--pur)}
.dash-cat.music .dash-cat-val{color:var(--grn)}
.dash-cat.funko .dash-cat-val{color:var(--pink)}
.dash-cat.pokemon .dash-cat-val{color:var(--gold)}
.dash-cat.comics .dash-cat-val{color:var(--red)}
.dash-section-title{font-size:10px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px}
.wish-dash-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px}
.wish-row{display:flex;align-items:center;gap:12px;background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rl);padding:12px;cursor:pointer;transition:border-color .13s,background .13s}
.wish-row:hover{border-color:var(--bd2);background:var(--s2)}
.wc{width:40px;height:56px;border-radius:4px;overflow:hidden;background:var(--s3);flex-shrink:0}
.wc img{width:100%;height:100%;object-fit:cover}
.wc-fb{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:16px;color:rgba(128,128,128,.2)}
.wi{flex:1;min-width:0}
.wi-t{font-size:12px;font-weight:600;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wi-a{font-size:10px;color:var(--tx2);margin-top:1px}
.wi-prices{display:flex;flex-direction:column;align-items:flex-end;gap:2px;flex-shrink:0}
.wi-pri{font-size:9px;padding:1px 6px;border-radius:999px;font-weight:700;text-transform:uppercase}
.wi-pri.High{background:var(--red-d);color:var(--red)}
.wi-pri.Medium{background:var(--gold-d);color:var(--gold)}
.wi-pri.Low{background:var(--grn-d);color:var(--grn)}

/* ─── BROWSE ─── */
.browse-filters{display:flex;gap:8px;margin-bottom:18px;align-items:center;flex-wrap:wrap}
.search-wrap{flex:1;min-width:220px;position:relative}
.search-wrap input{width:100%;background:var(--s1);border:.5px solid var(--bd2);border-radius:var(--r);color:var(--tx);font-family:var(--f);font-size:14px;padding:9px 38px 9px 13px;outline:none;transition:border-color .14s}
.search-wrap input:focus{border-color:var(--gold)}
.search-wrap input::placeholder{color:var(--tx3);opacity:.8}
.search-wrap .s-ico{position:absolute;right:11px;top:50%;transform:translateY(-50%);font-size:14px;color:var(--tx3);pointer-events:none}
.format-filters{display:flex;gap:6px;flex-wrap:wrap}
.ff-btn{padding:6px 12px;font-size:11px;font-weight:600;font-family:var(--f);background:var(--s2);color:var(--tx2);border:.5px solid var(--bd);border-radius:999px;cursor:pointer;transition:all .13s;white-space:nowrap}
.ff-btn:hover{color:var(--tx);border-color:var(--bd2)}
.ff-btn.on{color:var(--gold);border-color:var(--gold);background:var(--gold-d)}
.year-input{background:var(--s2);border:.5px solid var(--bd);border-radius:var(--r);color:var(--tx);font-family:var(--f);font-size:12px;padding:7px 10px;outline:none;width:80px;transition:border-color .14s}
.year-input:focus{border-color:var(--gold)}
.year-input::placeholder{color:var(--tx3)}
.browse-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:14px}
.bg-card{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rl);padding:13px 11px 11px;cursor:pointer;transition:border-color .13s,transform .13s,background .13s;text-align:center;display:flex;flex-direction:column;align-items:center}
.bg-card:hover{border-color:var(--bd2);transform:translateY(-3px);background:var(--s2)}
.bg-cover{width:76px;height:104px;border-radius:5px;overflow:hidden;margin-bottom:8px;background:var(--s3)}
.bg-cover img{width:100%;height:100%;object-fit:cover;display:block}
.bg-cover-fb{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:26px;color:rgba(128,128,128,.15);background:linear-gradient(145deg,#152030,#0c1520)}
body.light .bg-cover-fb{background:linear-gradient(145deg,#d5e0ee,#c5d0de)}
.bg-title{font-size:11px;font-weight:600;color:var(--tx);line-height:1.3;margin-bottom:2px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;width:100%}
.bg-author{font-size:10px;color:var(--tx3);width:100%;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bg-year{font-size:10px;color:var(--tx2);margin-top:2px}
.br-status{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:2px 7px;border-radius:999px;margin-top:4px}
.br-status.owned{background:var(--grn-d);color:var(--grn)}
.br-status.wanted{background:var(--pur-d);color:var(--pur)}
.browse-loading{grid-column:1/-1;text-align:center;padding:40px;font-size:13px;color:var(--tx3)}
.browse-empty{grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--tx3)}
.browse-empty .ei{font-size:40px;margin-bottom:12px;opacity:.2}
.browse-empty p{font-size:13px;line-height:1.8}

/* ─── BOOK / ITEM DETAIL ─── */
.bd-back{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--tx2);cursor:pointer;background:none;border:none;font-family:var(--f);padding:0;margin-bottom:16px;transition:color .12s}
.bd-back:hover{color:var(--tx)}
.bd-hero{display:flex;gap:22px;align-items:flex-start;background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rxl);padding:22px;margin-bottom:18px}
.bd-cover{width:120px;height:168px;border-radius:8px;overflow:hidden;background:var(--s3);flex-shrink:0}
.bd-cover img{width:100%;height:100%;object-fit:cover}
.bd-cover-fb{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:44px;color:rgba(128,128,128,.1);background:linear-gradient(145deg,#152030,#0c1520)}
body.light .bd-cover-fb{background:linear-gradient(145deg,#d5e0ee,#c5d0de)}
.bd-info{flex:1;min-width:0}
.bd-title{font-family:var(--fd);font-size:24px;font-weight:400;line-height:1.2;margin-bottom:4px}
.bd-author{font-size:13px;color:var(--tx2);margin-bottom:8px}
.bd-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:13px}
.bd-tag{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:2px 8px;border-radius:999px}
.bd-tag.format{background:var(--blue-d);color:var(--blue)}
.bd-tag.year{background:var(--s3);color:var(--tx2)}
.bd-desc{font-size:13px;color:var(--tx2);line-height:1.75;margin-bottom:15px;max-width:520px}
.bd-action-row{display:flex;gap:8px;flex-wrap:wrap}
.btn-add-col{padding:8px 16px;font-size:12px;font-weight:600;font-family:var(--f);background:var(--grn-d);color:var(--grn);border:.5px solid var(--grn);border-radius:var(--r);cursor:pointer;transition:all .13s}
.btn-add-col:hover,.btn-add-col.owned{background:var(--grn);color:#0a0b0d}
.btn-add-wish{padding:8px 16px;font-size:12px;font-weight:600;font-family:var(--f);background:var(--pur-d);color:var(--pur);border:.5px solid var(--pur);border-radius:var(--r);cursor:pointer;transition:all .13s}
.btn-add-wish:hover,.btn-add-wish.wanted{background:var(--pur);color:#0a0b0d}

/* editions */
.bd-editions{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rxl);padding:18px 22px;margin-bottom:18px}
.bd-sec-title{font-size:10px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:13px}
.ed-filters{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.ed-pill{padding:5px 11px;font-size:11px;font-weight:600;font-family:var(--f);background:var(--s3);color:var(--tx2);border:.5px solid var(--bd);border-radius:999px;cursor:pointer;transition:all .13s}
.ed-pill:hover{color:var(--tx);border-color:var(--bd2)}
.ed-pill.on{color:var(--gold);border-color:var(--gold);background:var(--gold-d)}
.editions-grid{display:flex;flex-direction:column;gap:8px}
.ed-row{display:flex;align-items:center;gap:12px;background:var(--s2);border:.5px solid var(--bd);border-radius:var(--r);padding:11px 13px;cursor:pointer;transition:border-color .13s}
.ed-row:hover{border-color:var(--bd2)}
.ed-row.ed-selected{border-color:var(--gold);background:var(--gold-d)}
.ed-cover{width:36px;height:50px;border-radius:3px;overflow:hidden;background:var(--s4);flex-shrink:0}
.ed-cover img{width:100%;height:100%;object-fit:cover}
.ed-cover-fb{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:12px;color:rgba(128,128,128,.1)}
.ed-info{flex:1;min-width:0}
.ed-fmt{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:2px}
.ed-fmt.hardcover{color:var(--gold)}
.ed-fmt.paperback{color:var(--blue)}
.ed-fmt.mass-market{color:var(--teal)}
.ed-fmt.ebook{color:var(--grn)}
.ed-fmt.other{color:var(--tx2)}
.ed-fmt.steelbook{color:var(--pink)}
.ed-fmt.blu-ray{color:var(--blue)}
.ed-fmt.dvd{color:var(--tx2)}
.ed-fmt.k4{color:var(--red)}
.ed-fmt.vinyl{color:var(--pur)}
.ed-fmt.cassette{color:var(--teal)}
.ed-fmt.cd{color:var(--grn)}
.ed-pub{font-size:11px;color:var(--tx2)}
.ed-isbn{font-size:9px;color:var(--tx3);font-family:var(--fm);margin-top:2px}
.ed-chk{width:16px;height:16px;border-radius:4px;border:.5px solid var(--bd2);display:flex;align-items:center;justify-content:center;font-size:9px;color:transparent;flex-shrink:0}
.ed-row.ed-selected .ed-chk{background:var(--gold);border-color:var(--gold);color:#0a0b0d}
.ed-loading{text-align:center;padding:20px;font-size:12px;color:var(--tx3)}
.ed-none{text-align:center;padding:20px;font-size:12px;color:var(--tx3);font-style:italic}

/* covers gallery */
.covers-gallery{display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:8px;margin-top:10px}
.cg-item{border-radius:5px;overflow:hidden;cursor:pointer;border:2px solid transparent;transition:border-color .13s;aspect-ratio:.67}
.cg-item:hover{border-color:var(--bd2)}
.cg-item.selected{border-color:var(--gold)}
.cg-item img{width:100%;height:100%;object-fit:cover;display:block}

/* ebay */
.bd-ebay{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rxl);padding:18px 22px;margin-bottom:18px}
.ebay-entry-row{display:flex;gap:8px;align-items:flex-end;margin-bottom:10px;flex-wrap:wrap}
.eef{display:flex;flex-direction:column;gap:4px;flex:1;min-width:80px}
.eef label{font-size:9px;font-weight:700;color:var(--tx2);text-transform:uppercase;letter-spacing:.08em}
.eef input{background:var(--s3);border:.5px solid var(--bd2);border-radius:var(--r);color:var(--tx);font-family:var(--f);font-size:13px;padding:7px 10px;outline:none;width:100%;transition:border-color .13s}
.eef input:focus{border-color:var(--gold)}
.eef input::placeholder{color:var(--tx3);opacity:.65}
.btn-log-ebay{padding:7px 12px;font-size:12px;font-weight:600;font-family:var(--f);background:var(--s3);color:var(--tx);border:.5px solid var(--bd2);border-radius:var(--r);cursor:pointer;transition:all .13s;white-space:nowrap;flex-shrink:0;height:34px}
.btn-log-ebay:hover{background:var(--gold);color:#0a0b0d;border-color:var(--gold)}
.ebay-sales-list{display:flex;flex-direction:column;gap:5px;margin-bottom:10px}
.es-pill{display:flex;align-items:center;gap:8px;background:var(--s2);border:.5px solid var(--bd);border-radius:var(--r);padding:7px 11px;font-size:11px}
.es-price{font-family:var(--fd);font-size:15px;color:var(--gold);min-width:55px}
.es-date{color:var(--tx2);min-width:78px}
.es-url{flex:1;overflow:hidden}
.es-url a{color:var(--blue);font-size:10px;text-decoration:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block}
.es-del{background:none;border:none;color:var(--tx3);cursor:pointer;font-size:12px;transition:color .12s;margin-left:auto;flex-shrink:0}
.es-del:hover{color:var(--red)}
.ebay-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px}
.est{background:var(--s2);border:.5px solid var(--bd);border-radius:var(--r);padding:9px;text-align:center}
.est .ev{font-family:var(--fd);font-size:19px;color:var(--gold)}
.est .el{font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:.07em}
.est.g .ev{color:var(--grn)}.est.r .ev{color:var(--red)}
.err-sm{font-size:11px;color:var(--red);margin-top:4px;display:none}

/* ─── COLLECTION / WISHLIST GRIDS ─── */
.grid-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px}
.grid-header h3{font-family:var(--fd);font-size:16px;font-weight:400;font-style:italic}
.icon-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(128px,1fr));gap:12px}
.ic{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rl);padding:11px 9px 9px;cursor:pointer;transition:border-color .13s,transform .13s,background .13s;position:relative;text-align:center;display:flex;flex-direction:column;align-items:center}
.ic:hover{border-color:var(--bd2);transform:translateY(-3px);background:var(--s2)}
.ic-cov{width:66px;height:94px;border-radius:5px;overflow:hidden;margin-bottom:7px;background:var(--s3)}
.ic-cov img{width:100%;height:100%;object-fit:cover}
.ic-cov-fb{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:22px;color:rgba(128,128,128,.1);background:linear-gradient(145deg,#152030,#0c1520)}
body.light .ic-cov-fb{background:linear-gradient(145deg,#d5e0ee,#c5d0de)}
.ic-t{font-size:10.5px;font-weight:600;color:var(--tx);line-height:1.3;margin-bottom:2px;width:100%;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.ic-a{font-size:9px;color:var(--tx3);width:100%;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ic-v{font-family:var(--fd);font-size:12px;color:var(--gold);margin-top:4px}
.ic-badge{position:absolute;top:5px;left:5px;font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;padding:2px 5px;border-radius:999px}
.ic-badge.Mint{background:var(--grn-d);color:var(--grn)}
.ic-badge.NearMint{background:var(--teal-d);color:var(--teal)}
.ic-badge.Good{background:var(--blue-d);color:var(--blue)}
.ic-badge.Fair{background:var(--gold-d);color:var(--gold)}
.ic-badge.Poor{background:var(--red-d);color:var(--red)}
.ic-format{position:absolute;bottom:5px;right:5px;font-size:8px;font-weight:700;padding:1px 4px;border-radius:3px;background:var(--s3);color:var(--tx3)}
.ic-pri{position:absolute;top:5px;right:5px;width:6px;height:6px;border-radius:50%}
.ic-pri.High{background:var(--red)}.ic-pri.Medium{background:var(--gold)}.ic-pri.Low{background:var(--grn)}
.empty-g{grid-column:1/-1;text-align:center;padding:64px 20px;color:var(--tx3)}
.empty-g .ei{font-size:42px;margin-bottom:12px;opacity:.18}
.empty-g p{font-size:13px;line-height:1.8}

/* dvd sub-filter */
.sub-filter-row{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap}
.sub-pill{padding:6px 14px;font-size:11px;font-weight:600;font-family:var(--f);background:var(--s2);color:var(--tx2);border:.5px solid var(--bd);border-radius:999px;cursor:pointer;transition:all .13s}
.sub-pill:hover{color:var(--tx);border-color:var(--bd2)}
.sub-pill.on{color:var(--pur);border-color:var(--pur);background:var(--pur-d)}

/* ─── OVERLAY / MODAL ─── */
.ov{position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:90;display:flex;align-items:center;justify-content:center;animation:fi .14s ease}
@keyframes fi{from{opacity:0}to{opacity:1}}
.modal{background:var(--s1);border:.5px solid var(--bd2);border-radius:var(--rxl);padding:22px;width:440px;max-width:calc(100vw - 24px);position:relative;animation:su .17s ease;max-height:90vh;overflow-y:auto}
@keyframes su{from{transform:translateY(8px);opacity:0}to{transform:translateY(0);opacity:1}}
.m-x{position:absolute;top:12px;right:12px;background:var(--s2);border:.5px solid var(--bd);color:var(--tx3);border-radius:var(--r);width:26px;height:26px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;transition:all .12s}
.m-x:hover{color:var(--tx)}
.m-cov{width:60px;height:84px;border-radius:6px;overflow:hidden;margin-bottom:11px;background:var(--s3)}
.m-cov img{width:100%;height:100%;object-fit:cover}
.m-cov-fb{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:22px;color:rgba(128,128,128,.1)}
.m-t{font-family:var(--fd);font-size:18px;font-weight:400;line-height:1.2;margin-bottom:2px}
.m-a{font-size:12px;color:var(--tx2);margin-bottom:13px}
.m-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:.5px solid var(--bd);font-size:12px}
.m-row:last-of-type{border:none}
.m-lbl{color:var(--tx3)}
.m-val{color:var(--tx);font-weight:500;text-align:right;flex:1;margin-left:12px}
.m-actions{display:flex;gap:7px;margin-top:14px;padding-top:12px;border-top:.5px solid var(--bd);flex-wrap:wrap}

/* add-to modal */
.atc-tabs{display:flex;gap:6px;margin-bottom:16px}
.atc-tab{flex:1;padding:8px;font-size:12px;font-weight:600;font-family:var(--f);background:var(--s2);color:var(--tx2);border:.5px solid var(--bd);border-radius:var(--r);cursor:pointer;transition:all .13s;text-align:center}
.atc-tab.on{color:var(--gold);border-color:var(--gold);background:var(--gold-d)}
.atc-zone{display:none}
.atc-zone.on{display:block}
.fl{font-size:9px;font-weight:700;color:var(--tx2);text-transform:uppercase;letter-spacing:.08em;display:block;margin-bottom:4px;margin-top:12px}
.fi{background:var(--s2);border:.5px solid var(--bd2);border-radius:var(--r);color:var(--tx);font-family:var(--f);font-size:13px;padding:8px 11px;outline:none;transition:border-color .13s;width:100%}
.fi:focus{border-color:var(--gold)}
.fi::placeholder{color:var(--tx3);opacity:.7}
select.fi option{background:#1a1c1e}
body.light select.fi option{background:#fff}
.ed-select-list{max-height:200px;overflow-y:auto;display:flex;flex-direction:column;gap:6px;margin-top:8px}
.ed-sel-item{display:flex;align-items:center;gap:10px;background:var(--s2);border:.5px solid var(--bd);border-radius:var(--r);padding:9px 12px;cursor:pointer;transition:border-color .13s}
.ed-sel-item:hover{border-color:var(--bd2)}
.ed-sel-item.chosen{border-color:var(--gold);background:var(--gold-d)}
.ed-sel-fmt{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--gold)}
.ed-sel-pub{font-size:11px;color:var(--tx2);flex:1}
.ed-sel-chk{font-size:12px;color:transparent}
.ed-sel-item.chosen .ed-sel-chk{color:var(--gold)}

/* covers modal section */
.covers-section{margin-top:14px}
.covers-section .bd-sec-title{margin-bottom:8px}
.covers-mini{display:flex;gap:6px;flex-wrap:wrap;max-height:160px;overflow-y:auto}
.cov-mini-item{width:44px;height:62px;border-radius:3px;overflow:hidden;cursor:pointer;border:2px solid transparent;transition:border-color .13s;flex-shrink:0}
.cov-mini-item:hover{border-color:var(--bd2)}
.cov-mini-item.chosen{border-color:var(--gold)}
.cov-mini-item img{width:100%;height:100%;object-fit:cover}
.cov-mini-fb{width:100%;height:100%;background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--tx3)}

/* settings page */
.settings-card{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rxl);padding:22px;margin-bottom:16px}
.settings-card h3{font-family:var(--fd);font-size:15px;font-weight:400;margin-bottom:16px;color:var(--tx)}
.settings-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:.5px solid var(--bd);gap:12px}
.settings-row:last-child{border:none}
.sr-info{flex:1}
.sr-label{font-size:13px;font-weight:500;color:var(--tx)}
.sr-sub{font-size:11px;color:var(--tx3);margin-top:2px}
.toggle{width:38px;height:22px;background:var(--s3);border-radius:999px;position:relative;cursor:pointer;border:none;transition:background .2s;flex-shrink:0}
.toggle.on{background:var(--gold)}
.toggle::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;background:#fff;border-radius:50%;transition:transform .2s}
.toggle.on::after{transform:translateX(16px)}
.avatar-upload{display:flex;align-items:center;gap:14px;margin-bottom:16px}
.avatar-big{width:72px;height:72px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:28px;color:#0a0b0d;overflow:hidden;flex-shrink:0}
.avatar-big img{width:100%;height:100%;object-fit:cover}

/* ─── FUNKO / POKEMON browse specifics ─── */
.funko-card{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rl);padding:13px 11px 11px;cursor:pointer;transition:border-color .13s,transform .13s,background .13s;text-align:center}
.funko-card:hover{border-color:var(--bd2);transform:translateY(-3px);background:var(--s2)}
.funko-img{width:84px;height:100px;margin:0 auto 8px;background:var(--s3);border-radius:6px;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:36px}
.funko-img img{width:100%;height:100%;object-fit:contain;padding:4px}

@media(max-width:640px){
  :root{--sw:52px}
  .sb-logo h1,.sb-uinfo,.sb-grp-hd span:first-child{display:none}
  .si{justify-content:center;padding:9px}
  .si span:not(.si-ico),.si-badge{display:none}
  .sb-arr{display:none}
  .sb-user{justify-content:center}
  .content{padding:14px 12px 80px}
  .topbar{padding:0 12px}
  .bd-hero{flex-direction:column}
  .dash-cat-grid{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>
<div class="shell">

<!-- ════ SIDEBAR ════ -->
<aside class="sb">
  <div class="sb-logo">
    <div class="sb-logo-mark">📚</div>
    <div><h1>Stacks</h1></div>
  </div>
  <nav class="sb-nav">
    <button class="si dash on" onclick="showPage('dash')"><span class="si-ico">📊</span><span>Dashboard</span></button>

    <div class="sb-grp op" id="grp-browse">
      <div class="sb-grp-hd" onclick="toggleGrp('browse')"><span>Browse</span><span class="sb-arr">▶</span></div>
      <div class="sb-kids">
        <button class="si browse" onclick="openBrowse('books')"><span class="si-ico">📖</span><span>Books</span></button>
        <button class="si browse" onclick="openBrowse('comics')"><span class="si-ico">💥</span><span>Comics</span></button>
        <button class="si browse" onclick="openBrowse('dvds')"><span class="si-ico">💿</span><span>DVDs</span></button>
        <button class="si browse" onclick="openBrowse('music')"><span class="si-ico">🎵</span><span>Music</span></button>
        <button class="si browse" onclick="openBrowse('funko')"><span class="si-ico">🧸</span><span>Funko</span></button>
        <button class="si browse" onclick="openBrowse('pokemon')"><span class="si-ico">⚡</span><span>Pokémon</span></button>
      </div>
    </div>

    <div class="sb-grp op" id="grp-col">
      <div class="sb-grp-hd" onclick="toggleGrp('col')"><span>My Collection</span><span class="sb-arr">▶</span></div>
      <div class="sb-kids">
        <button class="si col" data-view="col-books"   onclick="showColPage('col-books')"><span class="si-ico">📖</span><span>Books</span><span class="si-badge" id="nb-cb">0</span></button>
        <button class="si col" data-view="col-comics"  onclick="showColPage('col-comics')"><span class="si-ico">💥</span><span>Comics</span><span class="si-badge" id="nb-cc">0</span></button>
        <button class="si col" data-view="col-dvds"    onclick="showColPage('col-dvds')"><span class="si-ico">💿</span><span>DVDs</span><span class="si-badge" id="nb-cd">0</span></button>
        <button class="si col" data-view="col-music"   onclick="showColPage('col-music')"><span class="si-ico">🎵</span><span>Music</span><span class="si-badge" id="nb-ck">0</span></button>
        <button class="si col" data-view="col-funko"   onclick="showColPage('col-funko')"><span class="si-ico">🧸</span><span>Funko</span><span class="si-badge" id="nb-cf">0</span></button>
        <button class="si col" data-view="col-pokemon" onclick="showColPage('col-pokemon')"><span class="si-ico">⚡</span><span>Pokémon</span><span class="si-badge" id="nb-cp">0</span></button>
      </div>
    </div>

    <div class="sb-grp" id="grp-wish">
      <div class="sb-grp-hd" onclick="toggleGrp('wish')"><span>Wish List</span><span class="sb-arr">▶</span></div>
      <div class="sb-kids">
        <button class="si wish" data-view="wish-books"   onclick="showColPage('wish-books')"><span class="si-ico">📖</span><span>Books</span><span class="si-badge" id="nb-wb">0</span></button>
        <button class="si wish" data-view="wish-comics"  onclick="showColPage('wish-comics')"><span class="si-ico">💥</span><span>Comics</span><span class="si-badge" id="nb-wc">0</span></button>
        <button class="si wish" data-view="wish-dvds"    onclick="showColPage('wish-dvds')"><span class="si-ico">💿</span><span>DVDs</span><span class="si-badge" id="nb-wd">0</span></button>
        <button class="si wish" data-view="wish-music"   onclick="showColPage('wish-music')"><span class="si-ico">🎵</span><span>Music</span><span class="si-badge" id="nb-wk">0</span></button>
        <button class="si wish" data-view="wish-funko"   onclick="showColPage('wish-funko')"><span class="si-ico">🧸</span><span>Funko</span><span class="si-badge" id="nb-wf">0</span></button>
        <button class="si wish" data-view="wish-pokemon" onclick="showColPage('wish-pokemon')"><span class="si-ico">⚡</span><span>Pokémon</span><span class="si-badge" id="nb-wp">0</span></button>
      </div>
    </div>
  </nav>

  <div class="sb-user" onclick="showPage('settings')">
    <div class="sb-avatar" id="sb-avatar-el">?</div>
    <div class="sb-uinfo">
      <div class="sb-uname" id="sb-uname">Guest</div>
      <div class="sb-urole">Settings & Profile</div>
    </div>
    <span class="sb-settings-ico">⚙️</span>
  </div>
</aside>

<!-- ════ MAIN ════ -->
<main class="main">
  <div class="topbar">
    <h2 id="tb-title">Dashboard</h2>
    <div id="tb-actions"></div>
  </div>
  <div class="content">

    <!-- DASHBOARD -->
    <div id="page-dash" class="view on">
      <div class="dash-hero">
        <div class="dash-total-lbl">Total Collection Value</div>
        <div class="dash-total-val" id="d-total-val">$0.00</div>
        <div class="dash-total-sub" id="d-total-sub">Based on average eBay sale prices</div>
        <div class="dash-cat-grid">
          <div class="dash-cat books"><div class="dash-cat-lbl">📖 Books</div><div class="dash-cat-val" id="d-book-val">$0.00</div><div class="dash-cat-ct" id="d-book-ct">0 items</div></div>
          <div class="dash-cat movies"><div class="dash-cat-lbl">💿 DVDs</div><div class="dash-cat-val" id="d-dvd-val">$0.00</div><div class="dash-cat-ct" id="d-dvd-ct">0 items</div></div>
          <div class="dash-cat music"><div class="dash-cat-lbl">🎵 Music</div><div class="dash-cat-val" id="d-music-val">$0.00</div><div class="dash-cat-ct" id="d-music-ct">0 items</div></div>
          <div class="dash-cat funko"><div class="dash-cat-lbl">🧸 Funko</div><div class="dash-cat-val" id="d-funko-val">$0.00</div><div class="dash-cat-ct" id="d-funko-ct">0 items</div></div>
          <div class="dash-cat pokemon"><div class="dash-cat-lbl">⚡ Pokémon</div><div class="dash-cat-val" id="d-poke-val">$0.00</div><div class="dash-cat-ct" id="d-poke-ct">0 items</div></div>
          <div class="dash-cat comics"><div class="dash-cat-lbl">💥 Comics</div><div class="dash-cat-val" id="d-comic-val">$0.00</div><div class="dash-cat-ct" id="d-comic-ct">0 items</div></div>
        </div>
      </div>
      <div class="dash-section-title">Wish List — Market Overview</div>
      <div class="wish-dash-grid" id="dash-wish-grid">
        <div style="grid-column:1/-1;text-align:center;padding:40px;font-size:13px;color:var(--tx3)">Your wish list is empty. Browse any category to add items.</div>
      </div>
    </div>

    <!-- BROWSE PAGE -->
    <div id="page-browse" class="view">
      <div class="browse-filters" id="br-filters-row">
        <div class="search-wrap">
          <input id="br-search" placeholder="Search…" onkeydown="if(event.key==='Enter')brSearch()"/>
          <span class="s-ico">🔍</span>
        </div>
        <div class="format-filters" id="br-fmt-filters"></div>
        <input class="year-input" id="br-year" type="number" placeholder="Year" min="1000" max="2099" onkeydown="if(event.key==='Enter')brSearch()"/>
        <button class="btn-primary" onclick="brSearch()">Search</button>
      </div>
      <!-- DVD sub-filter -->
      <div id="dvd-sub-filter" style="display:none" class="sub-filter-row">
        <button class="sub-pill on" data-dvdsub="all" onclick="setDvdSub(this,'all')">All</button>
        <button class="sub-pill" data-dvdsub="movie" onclick="setDvdSub(this,'movie')">Movies</button>
        <button class="sub-pill" data-dvdsub="tv" onclick="setDvdSub(this,'tv')">TV Shows</button>
      </div>
      <div class="browse-grid" id="br-grid">
        <div class="browse-empty"><div class="ei" id="br-empty-ico">📚</div><p id="br-empty-txt">Search for any book above.<br>Results pull from the Open Library database.</p></div>
      </div>
    </div>

    <!-- ITEM DETAIL PAGE -->
    <div id="page-item" class="view">
      <button class="bd-back" onclick="backToBrowse()">← Back</button>
      <div class="bd-hero">
        <div class="bd-cover" id="bd-cover"></div>
        <div class="bd-info">
          <div class="bd-title" id="bd-title"></div>
          <div class="bd-author" id="bd-author"></div>
          <div class="bd-tags" id="bd-tags"></div>
          <div class="bd-desc" id="bd-desc"></div>
          <div class="bd-action-row">
            <button class="btn-add-col" id="btn-own" onclick="openAddModal('col')">+ Add to Collection</button>
            <button class="btn-add-wish" id="btn-wish" onclick="openAddModal('wish')">+ Add to Wish List</button>
          </div>
        </div>
      </div>
      <!-- Editions / Formats -->
      <div class="bd-editions" id="bd-editions-section">
        <div class="bd-sec-title" id="editions-title">Editions & Formats</div>
        <div class="ed-filters" id="ed-filters"></div>
        <div class="ed-yr-row" id="ed-yr-wrap" style="display:flex;gap:8px;margin-bottom:12px;align-items:center">
          <input class="year-input" id="ed-yr" type="number" placeholder="Filter year" onchange="filterEditions()"/>
          <span style="font-size:11px;color:var(--tx3)">Filter by year</span>
        </div>
        <div class="editions-grid" id="editions-grid"><div class="ed-loading">Loading…</div></div>
      </div>
      <!-- Alternate Covers -->
      <div class="bd-editions" id="bd-covers-section" style="display:none">
        <div class="bd-sec-title">Alternate Covers</div>
        <div class="covers-gallery" id="covers-gallery"></div>
      </div>
      <!-- eBay Sales -->
      <div class="bd-ebay">
        <div class="bd-sec-title">eBay Sales Data <span style="font-size:9px;font-weight:400;color:var(--tx3);text-transform:none;letter-spacing:0">— community logged sale prices</span></div>
        <div class="ebay-entry-row">
          <div class="eef" style="flex:2;min-width:140px"><label>eBay Listing URL <span style="color:var(--red)">*</span></label><input id="eb-url" type="url" placeholder="https://www.ebay.com/itm/…"/></div>
