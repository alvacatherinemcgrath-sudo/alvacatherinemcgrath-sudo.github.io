}

async function brSearchBooks(q,yr){
  // exclude comics/graphic novels from books search, include them for comics
  let url=`https://openlibrary.org/search.json?q=${encodeURIComponent(q)}&limit=24&fields=key,title,author_name,first_publish_year,cover_i,isbn,subject,ia`;
  if(yr)url+=`&publish_year=${yr}`;
  const r=await fetch(url);const data=await r.json();
  let docs=data.docs||[];
  if(_brType==='books'){
    docs=docs.filter(d=>{
      const subs=(d.subject||[]).map(s=>s.toLowerCase());
      return !subs.some(s=>s.includes('comic')||s.includes('graphic novel')||s.includes('manga'));
    });
  } else {
    // comics — prefer comic-related results
    docs=docs.filter(d=>{
      const subs=(d.subject||[]).map(s=>s.toLowerCase());
      const title=(d.title||'').toLowerCase();
      return subs.some(s=>s.includes('comic')||s.includes('graphic novel')||s.includes('manga'))||title.includes('comic')||title.includes('omnibus')||title.includes('volume')||title.includes('vol.')||true; // show all for now
    });
  }
  _brResults=docs;renderBrGrid();
}

