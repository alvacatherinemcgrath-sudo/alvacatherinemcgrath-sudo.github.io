function setAtcTab(t){
  ATCmode=t;
  g('atc-t-col').className='atc-tab'+(t==='col'?' on':'');
  g('atc-t-wish').className='atc-tab'+(t==='wish'?' on':'');
  g('atc-col').className='atc-zone'+(t==='col'?' on':'');
  g('atc-wish').className='atc-zone'+(t==='wish'?' on':'');
}
function confirmAdd(){
  if(!CUR_ITEM)return;
  const it=CUR_ITEM;
  const wk=it.key;
  const selEd=ATCselEdIdx!==null?CUR_EDITIONS[ATCselEdIdx]:null;
  const selCov=ATCselCovIdx!==null&&CUR_COVERS[ATCselCovIdx]?CUR_COVERS[ATCselCovIdx]:null;
  const defaultCov=it.poster||(it.cover_i?`https://covers.openlibrary.org/b/id/${it.cover_i}-M.jpg`:(it.mbCoverId?`https://coverartarchive.org/release-group/${it.mbCoverId}/front-250`:null));
  const cat=_brType==='comics'?'comics':_brType;
  const base={
    id:Date.now(),title:it.title||'',
    author:(it.author_name||[]).slice(0,2).join(', ')||'',
    year:it.first_publish_year||it.year||'',
    coverUrl:selCov?selCov.url:defaultCov,
    ebayKey:wk,cat,
    format:selEd?selEd.fmt:'',
    isbn:selEd?selEd.isbn:'',
    publisher:selEd?selEd.pub:'',
    edYear:selEd?selEd.yr:null,
    dvdSubType:it.type||''
  };
  if(ATCmode==='col'){
    USER.wish[cat]=USER.wish[cat].filter(i=>i.ebayKey!==wk);
    if(!USER.col[cat].some(i=>i.ebayKey===wk&&i.format===(selEd?selEd.fmt:'')))
      USER.col[cat].push({...base,condition:g('atc-cond').value,notes:g('atc-notes').value.trim()});
  } else {
    USER.wish[cat]=USER.wish[cat].filter(i=>i.ebayKey!==wk);
    USER.wish[cat].push({...base,budget:parseFloat(g('atc-budget').value)||0,priority:g('atc-pri').value});
  }
  persist();updateCounts();
  g('atc-ov').style.display='none';
  updateDetailButtons();
}

function updateDetailButtons(){
  if(!CUR_ITEM)return;
  const cat=_brType==='comics'?'comics':_brType;
  const wk=CUR_ITEM.key;
  const isOwned=(USER.col[cat]||[]).some(i=>i.ebayKey===wk);
  const isWanted=(USER.wish[cat]||[]).some(i=>i.ebayKey===wk);
  const ob=g('btn-own'),wb=g('btn-wish');
  if(ob){ob.className='btn-add-col'+(isOwned?' owned':'');ob.textContent=isOwned?'✓ In Collection':'+ Add to Collection';}
  if(wb){wb.className='btn-add-wish'+(isWanted?' wanted':'');wb.textContent=isWanted?'✓ On Wish List':'+ Add to Wish List';}
}

/* ══════════ MANUAL ADD ══════════ */
function openManualAdd(cat,title){
  // Quick manual add flow
  const name=prompt('Item name:',title||'');
  if(!name)return;
  const fmt=prompt(`Format (${(FORMATS[cat]||['Standard']).join(', ')}):`,FORMATS[cat]?.[0]||'Standard');
  const mode=confirm('Add to Collection? (Cancel = Wish List)')?'col':'wish';
  const id=Date.now();
  const key=cat+'_manual_'+id;
  const base={id,title:name,author:'',year:'',coverUrl:null,ebayKey:key,cat,format:fmt||'Standard',isbn:'',publisher:'',dvdSubType:''};
  if(mode==='col'){
    const cond=prompt('Condition (Mint/NearMint/Good/Fair/Poor):','Good')||'Good';
    USER.col[cat].push({...base,condition:cond,notes:''});
  } else {
    USER.wish[cat].push({...base,budget:0,priority:'Medium'});
  }
  persist();updateCounts();alert(`"${name}" added to your ${mode==='col'?'collection':'wish list'}!`);
}

/* ══════════ COLLECTION GRID ══════════ */
function renderColGrid(view){
  const[sec,type]=view.split('-');
  const store=sec==='col'?USER.col:USER.wish;
  let items=(store[type]||[]);
  if(type==='dvds'&&_colDvdSub!=='all'){
    items=items.filter(it=>it.dvdSubType?it.dvdSubType.toLowerCase().includes(_colDvdSub):true);
  }
  const el=g('col-grid');
  if(!items.length){
    const icos={books:'📖',comics:'💥',dvds:'💿',music:'🎵',funko:'🧸',pokemon:'⚡'};
    el.innerHTML=`<div class="empty-g"><div class="ei">${icos[type]||'📦'}</div><p>No ${type} in your ${sec==='col'?'collection':'wish list'} yet.</p></div>`;
    return;
  }
  el.innerHTML=items.map(it=>{
    const letter=(it.title||'?').charAt(0).toUpperCase();
    const avg=it.ebayKey?ebayAvg(it.ebayKey):0;
    const covHtml=it.coverUrl?`<img src="${x(it.coverUrl)}" loading="lazy" onerror="this.style.display='none';this.nextSibling.style.display='flex'" alt=""><div class="ic-cov-fb" style="display:none">${letter}</div>`:`<div class="ic-cov-fb">${letter}</div>`;
    const fmtBadge=it.format?`<span class="ic-format">${it.format.substring(0,6)}</span>`:'';
    if(sec==='col'){
      const cond=it.condition||'Good';
      return `<div class="ic" onclick="openItemModal('col','${type}',${it.id})">
        <span class="ic-badge ${cond}">${cond==='NearMint'?'NM':cond.substring(0,4)}</span>
        ${fmtBadge}
        <div class="ic-cov">${covHtml}</div>
        <div class="ic-t">${x(it.title)}</div>
        <div class="ic-a">${x(it.author||it.publisher||'')}</div>
        ${avg?`<div class="ic-v">$${avg.toFixed(2)}</div>`:''}
      </div>`;
    } else {
      return `<div class="ic" onclick="openItemModal('wish','${type}',${it.id})">
        <span class="ic-pri ${it.priority||'Medium'}"></span>
        ${fmtBadge}
        <div class="ic-cov">${covHtml}</div>
        <div class="ic-t">${x(it.title)}</div>
        <div class="ic-a">${x(it.author||it.publisher||'')}</div>
        ${avg?`<div class="ic-v">$${avg.toFixed(2)}</div>`:`<div class="ic-v" style="color:var(--tx3);font-size:10px">No data</div>`}
      </div>`;
    }
  }).join('');
}

/* ══════════ ITEM MODAL ══════════ */
function openItemModal(sec,type,id){
  const store=sec==='col'?USER.col:USER.wish;
  const it=(store[type]||[]).find(i=>i.id===id);if(!it)return;
  const letter=(it.title||'?').charAt(0).toUpperCase();
  const covHtml=it.coverUrl?`<img src="${x(it.coverUrl)}" onerror="this.style.display='none';this.nextSibling.style.display='flex'" alt=""><div class="m-cov-fb" style="display:none">${letter}</div>`:`<div class="m-cov-fb">${letter}</div>`;
  const avg=it.ebayKey?ebayAvg(it.ebayKey):0;
  let rows='';
  if(it.format)rows+=mr('Format',it.format);
  if(sec==='col'){
    rows+=mr('Condition',it.condition||'—');
    if(it.year)rows+=mr('Year',it.year);
    if(it.publisher)rows+=mr('Publisher',it.publisher);
    if(it.isbn)rows+=mr('ISBN',it.isbn);
    if(avg)rows+=mr('eBay Avg','$'+avg.toFixed(2));
    if(it.notes)rows+=mr('Notes',it.notes);
  } else {
    rows+=mr('Priority',it.priority||'—');
    if(it.budget)rows+=mr('Budget','$'+parseFloat(it.budget).toFixed(2));
    if(it.year)rows+=mr('Year',it.year);
    if(avg)rows+=mr('eBay Avg','$'+avg.toFixed(2));
  }
  const gotBtn=sec==='wish'?`<button style="flex:1;padding:8px;font-size:12px;font-weight:600;font-family:var(--f);background:var(--grn-d);color:var(--grn);border:.5px solid var(--grn);border-radius:var(--r);cursor:pointer" onclick="gotItem('${type}',${it.id});g('item-ov').style.display='none'">✓ Got it!</button>`:'';
  const delBtn=`<button style="padding:8px 12px;font-size:12px;font-weight:500;font-family:var(--f);background:transparent;color:var(--tx3);border:.5px solid var(--bd2);border-radius:var(--r);cursor:pointer" onclick="removeUserItem('${sec}','${type}',${it.id});g('item-ov').style.display='none'">✕ Remove</button>`;
  g('item-modal').innerHTML=`<button class="m-x" onclick="g('item-ov').style.display='none'">✕</button>
    <div class="m-cov">${covHtml}</div>
    <div class="m-t">${x(it.title)}</div>
    <div class="m-a">${x(it.author||it.publisher||'—')}</div>
    ${rows}
    <div class="m-actions">${gotBtn}${delBtn}</div>`;
  g('item-ov').style.display='flex';
}
function mr(l,v){return`<div class="m-row"><span class="m-lbl">${l}</span><span class="m-val">${x(String(v))}</span></div>`;}

/* ══════════ DATA OPS ══════════ */
function gotItem(type,id){
  const it=USER.wish[type].find(i=>i.id===id);if(!it)return;
  USER.col[type].push({...it,id:Date.now(),condition:'Good'});
  USER.wish[type]=USER.wish[type].filter(i=>i.id!==id);
  persist();updateCounts();renderColGrid(_curColView);
}
function removeUserItem(sec,type,id){
  const store=sec==='col'?USER.col:USER.wish;
  store[type]=store[type].filter(i=>i.id!==id);
  persist();updateCounts();renderColGrid(_curColView);
}
function updateCounts(){
  const cats=['books','comics','dvds','music','funko','pokemon'];
  const ids={books:'cb',comics:'cc',dvds:'cd',music:'ck',funko:'cf',pokemon:'cp'};
  cats.forEach(c=>{
    const ci=ids[c];
    const wcol=g('nb-'+ci),wwish=g('nb-w'+ci.charAt(1));
    if(wcol)wcol.textContent=USER.col[c].length;
    if(wwish)wwish.textContent=USER.wish[c].length;
  });
}

/* ══════════ HELPERS ══════════ */
function g(id){return document.getElementById(id)}
function x(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
function fmtDate(d){if(!d)return'—';try{const[y,m,day]=d.split('-').map(Number);return['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][m-1]+' '+day+', '+y;}catch(e){return d;}}
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    if(g('item-ov').style.display!=='none')g('item-ov').style.display='none';
    else if(g('atc-ov').style.display!=='none')g('atc-ov').style.display='none';
  }
});

/* ══════════ INIT ══════════ */
updateCounts();buildDash();
['grp-col','grp-browse'].forEach(id=>{const el=g(id);if(el)el.classList.add('op');});
// Prime browse page for books so format pills/placeholder are correct on first visit
(function initBrowseDefaults(){
  const pills=FORMAT_PILLS['books']||[];
  g('br-fmt-filters').innerHTML=`<button class="ff-btn on" data-fmt="all" onclick="setBrFmt(this,'all')">All</button>`+pills.map(f=>`<button class="ff-btn" data-fmt="${f}" onclick="setBrFmt(this,'${f}')">${f}</button>`).join('');
  g('br-search').placeholder=BROWSE_PLACEHOLDER['books'];
  g('dvd-sub-filter').style.display='none';
})();
</script>
