function classifyFmt(s,type='books'){
  if(!s)return'other';const l=s.toLowerCase();
  if(type==='books'||type==='comics'){
    if(l.includes('hardcover')||l.includes('hardback'))return'Hardcover';
    if(l.includes('mass market')||l.includes('mass-market'))return'Mass Market Paperback';
    if(l.includes('paperback')||l.includes('softcover')||l.includes('trade paper'))return'Paperback';
    if(l.includes('ebook')||l.includes('e-book')||l.includes('kindle')||l.includes('digital'))return'eBook';
    if(l.includes('audio'))return'skip';
  }
  return'other';
}
