<script>
/* ══════════ CONFIG ══════════ */
const FORMATS={
  books:['Hardcover','Paperback','Mass Market Paperback','eBook','Audiobook'],
  comics:['Single Issue','Trade Paperback','Hardcover','Omnibus','Graphic Novel'],
  dvds:['DVD','Blu-ray','4K UHD','Steelbook','Digital'],
  music:['CD','Vinyl','Cassette','Digital'],
  funko:['Standard','Chase','Exclusive','Glow','Flocked'],
  pokemon:['Booster Pack','Single Card','Graded PSA','Graded BGS','Sealed Box','ETB']
};
const FORMAT_PILLS={
  books:['Hardcover','Paperback','Mass Market Paperback','eBook'],
  comics:['Single Issue','Trade Paperback','Hardcover','Omnibus'],
  dvds:['DVD','Blu-ray','4K UHD','Steelbook'],
  music:['CD','Vinyl','Cassette'],
  funko:['Standard','Chase','Exclusive'],
  pokemon:['Single Card','Booster Pack','Graded PSA','Sealed Box']
};
const BROWSE_PLACEHOLDER={
  books:'Search books by title, author, ISBN…',
  comics:'Search comics, graphic novels, omnibuses…',
  dvds:'Search movies or TV shows…',
  music:'Search albums, artists, singles…',
  funko:'Search Funko Pop figures…',
  pokemon:'Search Pokémon cards or sets…'
};
const BROWSE_EMPTY_ICO={books:'📖',comics:'💥',dvds:'💿',music:'🎵',funko:'🧸',pokemon:'⚡'};

/* ══════════ STATE ══════════ */
const DB={bookSales:{}};
const USER={col:{books:[],comics:[],dvds:[],music:[],funko:[],pokemon:[]},wish:{books:[],comics:[],dvds:[],music:[],funko:[],pokemon:[]}};
let ACCOUNT=null; // {username, avatarUrl, theme:'dark'|'light'}
let CUR_ITEM=null;
let CUR_EDITIONS=[];
let CUR_COVERS=[];
let ED_FILTER='all';
let ATCmode='col';
let ATCselEdIdx=null;
let ATCselCovIdx=null;
let _brResults=[];
let _brFmt='all';
let _brType='books';
let _dvdSub='all';
let _curColView='col-books';

/* ══════════ PERSIST ══════════ */
(function load(){
  try{
    const d=JSON.parse(localStorage.getItem('stacks_v2')||'null');
    if(!d)return;
    if(d.col)Object.keys(d.col).forEach(k=>{if(USER.col[k])USER.col[k]=d.col[k]});
    if(d.wish)Object.keys(d.wish).forEach(k=>{if(USER.wish[k])USER.wish[k]=d.wish[k]});
    if(d.bookSales)Object.assign(DB.bookSales,d.bookSales);
    if(d.account)ACCOUNT=d.account;
  }catch(e){}
  if(ACCOUNT){
    applyAccount();
    hideAuth();
  }
})();

function persist(){
  try{localStorage.setItem('stacks_v2',JSON.stringify({col:USER.col,wish:USER.wish,bookSales:DB.bookSales,account:ACCOUNT}));}catch(e){}
}

/* ══════════ AUTH ══════════ */
function setAuthTab(t){
  g('auth-t-in').className='auth-tab'+(t==='in'?' on':'');
  g('auth-t-up').className='auth-tab'+(t==='up'?' on':'');
  g('auth-in').style.display=t==='in'?'':'none';
  g('auth-up').style.display=t==='up'?'':'none';
  g('auth-err').textContent='';
}
function doSignIn(){
  const user=g('signin-user').value.trim();
  const pass=g('signin-pass').value;
  if(!user||!pass){g('auth-err').textContent='Please fill in all fields.';return;}
  const stored=JSON.parse(localStorage.getItem('stacks_accounts')||'{}');
  if(!stored[user]||stored[user].pass!==btoa(pass)){g('auth-err').textContent='Invalid username or password.';return;}
  ACCOUNT={username:user,avatarUrl:stored[user].avatarUrl||null,theme:stored[user].theme||'dark'};
  // load that user's data
  const ud=JSON.parse(localStorage.getItem('stacks_data_'+user)||'null');
  if(ud){
    if(ud.col)Object.keys(ud.col).forEach(k=>{if(USER.col[k])USER.col[k]=ud.col[k]});
    if(ud.wish)Object.keys(ud.wish).forEach(k=>{if(USER.wish[k])USER.wish[k]=ud.wish[k]});
    if(ud.bookSales)Object.assign(DB.bookSales,ud.bookSales);
  }
  persist();applyAccount();hideAuth();
}
function doSignUp(){
  const user=g('signup-user').value.trim();
  const pass=g('signup-pass').value;
  const pass2=g('signup-pass2').value;
  const err=g('auth-err');
  if(!user||!pass||!pass2){err.textContent='Please fill in all fields.';return;}
  if(!/^[a-zA-Z0-9_]{3,20}$/.test(user)){err.textContent='Username: 3–20 chars, letters/numbers/underscores only.';return;}
  if(pass.length<6){err.textContent='Password must be at least 6 characters.';return;}
  if(pass!==pass2){err.textContent='Passwords do not match.';return;}
  const stored=JSON.parse(localStorage.getItem('stacks_accounts')||'{}');
  if(stored[user]){err.textContent='Username already taken.';return;}
  stored[user]={pass:btoa(pass),avatarUrl:null,theme:'dark'};
  localStorage.setItem('stacks_accounts',JSON.stringify(stored));
  ACCOUNT={username:user,avatarUrl:null,theme:'dark'};
  persist();applyAccount();hideAuth();
}
function skipAuth(){
  ACCOUNT={username:'Guest',avatarUrl:null,theme:'dark'};
  hideAuth();applyAccount();
}
function hideAuth(){g('auth-ov').style.display='none';}
function applyAccount(){
  if(!ACCOUNT)return;
  const letter=ACCOUNT.username.charAt(0).toUpperCase();
  g('sb-uname').textContent=ACCOUNT.username;
  g('sb-avatar-el').innerHTML=ACCOUNT.avatarUrl?`<img src="${ACCOUNT.avatarUrl}" alt="">`:`${letter}`;
  g('settings-uname-display').textContent=ACCOUNT.username;
  const aBig=g('settings-avatar');
  if(aBig)aBig.innerHTML=ACCOUNT.avatarUrl?`<img src="${ACCOUNT.avatarUrl}" alt="">`:`${letter}`;
  if(ACCOUNT.theme==='light'&&!document.body.classList.contains('light')){document.body.classList.add('light');g('theme-toggle').classList.add('on');}
  else if(ACCOUNT.theme!=='light'){document.body.classList.remove('light');g('theme-toggle').classList.remove('on');}
  updateCounts();buildDash();
}
function signOut(){ACCOUNT=null;persist();location.reload();}
function confirmDeleteAccount(){
  if(!confirm('Permanently delete your account and ALL data? This cannot be undone.'))return;
  const stored=JSON.parse(localStorage.getItem('stacks_accounts')||'{}');
  if(ACCOUNT)delete stored[ACCOUNT.username];
  localStorage.setItem('stacks_accounts',JSON.stringify(stored));
  localStorage.removeItem('stacks_v2');
  if(ACCOUNT)localStorage.removeItem('stacks_data_'+ACCOUNT.username);
  location.reload();
}
function toggleTheme(){
  const isLight=document.body.classList.toggle('light');
  g('theme-toggle').classList.toggle('on',isLight);
  if(ACCOUNT){ACCOUNT.theme=isLight?'light':'dark';persist();}
}
function promptChangeUsername(){
  const n=prompt('New username (3–20 chars, letters/numbers/underscores):',ACCOUNT?ACCOUNT.username:'');
  if(!n||!/^[a-zA-Z0-9_]{3,20}$/.test(n.trim())){alert('Invalid username.');return;}
  const nn=n.trim();
  const stored=JSON.parse(localStorage.getItem('stacks_accounts')||'{}');
  if(stored[nn]&&nn!==ACCOUNT.username){alert('Username taken.');return;}
  if(ACCOUNT){
    const old=ACCOUNT.username;
    if(stored[old]){stored[nn]=stored[old];delete stored[old];}
    localStorage.setItem('stacks_accounts',JSON.stringify(stored));
    ACCOUNT.username=nn;
    persist();applyAccount();
  }
}
function handleAvatarUpload(inp){
  const file=inp.files[0];if(!file)return;
  const r=new FileReader();
  r.onload=e=>{
    const url=e.target.result;
    if(ACCOUNT)ACCOUNT.avatarUrl=url;
    const stored=JSON.parse(localStorage.getItem('stacks_accounts')||'{}');
    if(ACCOUNT&&stored[ACCOUNT.username])stored[ACCOUNT.username].avatarUrl=url;
    localStorage.setItem('stacks_accounts',JSON.stringify(stored));
    persist();applyAccount();
  };
  r.readAsDataURL(file);
}

/* ══════════ NAV ══════════ */
let _curPage='dash';
function showPage(p){
  if(p==='browse'){openBrowse(_brType||'books');return;}
  _curPage=p;
  ['dash','browse','item','col','settings'].forEach(id=>g('page-'+id).classList.remove('on'));
  g('page-'+p).classList.add('on');
  document.querySelectorAll('.si').forEach(b=>b.classList.remove('on'));
  const titles={dash:'Dashboard',settings:'Settings'};
  g('tb-title').textContent=titles[p]||p;
  g('tb-actions').innerHTML='';
  if(p==='dash')buildDash();
  if(p==='settings')applyAccount();
}
function showColPage(view){
  _curColView=view;_curPage='col';
  ['dash','browse','item','col','settings'].forEach(id=>g('page-'+id).classList.remove('on'));
  g('page-col').classList.add('on');
  document.querySelectorAll('.si').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll(`[data-view="${view}"]`).forEach(b=>b.classList.add('on'));
  const map={
    'col-books':'My Books','col-comics':'My Comics','col-dvds':'My DVDs','col-music':'My Music','col-funko':'My Funko Pops','col-pokemon':'My Pokémon Cards',
    'wish-books':'Wish List — Books','wish-comics':'Wish List — Comics','wish-dvds':'Wish List — DVDs','wish-music':'Wish List — Music','wish-funko':'Wish List — Funko','wish-pokemon':'Wish List — Pokémon'
  };
  g('tb-title').textContent=map[view]||view;
  g('col-page-title').textContent=map[view]||view;
  g('tb-actions').innerHTML='';
  const[sec,type]=view.split('-');
  const csf=g('col-sub-filters');
  if(type==='dvds'){
    csf.innerHTML=`<div class="sub-filter-row" style="margin-bottom:0">
      <button class="sub-pill on" data-sub="all" onclick="setColDvdSub(this,'all')">All</button>
      <button class="sub-pill" data-sub="movie" onclick="setColDvdSub(this,'movie')">Movies</button>
      <button class="sub-pill" data-sub="tv" onclick="setColDvdSub(this,'tv')">TV Shows</button>
    </div>`;
  } else csf.innerHTML='';
  renderColGrid(view);
}
let _colDvdSub='all';
function setColDvdSub(btn,v){
  _colDvdSub=v;
  document.querySelectorAll('#col-sub-filters .sub-pill').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');renderColGrid(_curColView);
}
function toggleGrp(id){g('grp-'+id).classList.toggle('op');}

/* ══════════ DASHBOARD ══════════ */
function ebayAvg(key){const s=DB.bookSales[key]||[];return s.length?s.reduce((a,b)=>a+b.price,0)/s.length:0;}
function buildDash(){
  let total=0;
  const cats={books:0,dvds:0,music:0,funko:0,pokemon:0,comics:0};
  const cts={books:0,dvds:0,music:0,funko:0,pokemon:0,comics:0};
  Object.keys(cats).forEach(c=>{
    (USER.col[c]||[]).forEach(it=>{const v=it.ebayKey?ebayAvg(it.ebayKey):0;cats[c]+=v;cts[c]++;total+=v;});
  });
  g('d-total-val').textContent='$'+total.toFixed(2);
  const tot=Object.values(cts).reduce((a,b)=>a+b,0);
  g('d-total-sub').textContent=`Based on ${tot} items using average eBay sale prices`;
  g('d-book-val').textContent='$'+cats.books.toFixed(2);g('d-book-ct').textContent=cts.books+' item'+(cts.books!==1?'s':'');
  g('d-dvd-val').textContent='$'+cats.dvds.toFixed(2);g('d-dvd-ct').textContent=cts.dvds+' item'+(cts.dvds!==1?'s':'');
  g('d-music-val').textContent='$'+cats.music.toFixed(2);g('d-music-ct').textContent=cts.music+' item'+(cts.music!==1?'s':'');
  g('d-funko-val').textContent='$'+cats.funko.toFixed(2);g('d-funko-ct').textContent=cts.funko+' item'+(cts.funko!==1?'s':'');
  g('d-poke-val').textContent='$'+cats.pokemon.toFixed(2);g('d-poke-ct').textContent=cts.pokemon+' item'+(cts.pokemon!==1?'s':'');
  g('d-comic-val').textContent='$'+cats.comics.toFixed(2);g('d-comic-ct').textContent=cts.comics+' item'+(cts.comics!==1?'s':'');
  const all=Object.keys(USER.wish).reduce((a,k)=>a.concat((USER.wish[k]||[]).map(it=>({...it,_cat:k}))),[]);
  const wg=g('dash-wish-grid');
  if(!all.length){wg.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px;font-size:13px;color:var(--tx3)">Your wish list is empty.</div>';return;}
  wg.innerHTML=all.map(it=>{
    const avg=it.ebayKey?ebayAvg(it.ebayKey):0;
    const letter=(it.title||'?').charAt(0).toUpperCase();
    const covHtml=it.coverUrl?`<img src="${x(it.coverUrl)}" onerror="this.style.display='none';this.nextSibling.style.display='flex'" alt=""><div class="wc-fb" style="display:none">${letter}</div>`:`<div class="wc-fb">${letter}</div>`;
    return `<div class="wish-row" onclick="openItemModal('wish','${it._cat}',${it.id})">
      <div class="wc">${covHtml}</div>
      <div class="wi"><div class="wi-t">${x(it.title||'')}</div><div class="wi-a">${x(it.author||it.publisher||'')}</div>
        <div class="wi-a" style="margin-top:3px"><span class="wi-pri ${it.priority||'Medium'}">${it.priority||'Medium'}</span></div>
      </div>
      <div class="wi-prices">
        ${it.budget?`<div class="wi-retail" style="font-size:10px;color:var(--tx3)">Budget: $${parseFloat(it.budget).toFixed(2)}</div>`:''}
        ${avg?`<div class="wi-ebay" style="font-family:var(--fd);font-size:15px;color:var(--gold)">$${avg.toFixed(2)}</div><div class="wi-retail" style="font-size:9px;color:var(--tx3)">eBay avg</div>`:'<div style="font-size:9px;color:var(--tx3)">No eBay data</div>'}
      </div>
    </div>`;
  }).join('');
}

/* ══════════ BROWSE ══════════ */
function openBrowse(type){
  _brType=type;_brResults=[];_brFmt='all';_dvdSub='all';
  showPage('browse');
  g('tb-title').textContent='Browse '+type.charAt(0).toUpperCase()+type.slice(1);
  g('br-search').value='';g('br-year').value='';
  g('br-search').placeholder=BROWSE_PLACEHOLDER[type]||'Search…';
  g('br-empty-ico').textContent=BROWSE_EMPTY_ICO[type]||'📦';
  g('br-empty-txt').innerHTML=`Search for ${type} above.<br>Results from open databases.`;
  g('br-grid').innerHTML=`<div class="browse-empty"><div class="ei">${BROWSE_EMPTY_ICO[type]||'📦'}</div><p>Search for ${type} above.</p></div>`;
  // format pills
  const pills=FORMAT_PILLS[type]||[];
  g('br-fmt-filters').innerHTML=`<button class="ff-btn on" data-fmt="all" onclick="setBrFmt(this,'all')">All</button>`+pills.map(f=>`<button class="ff-btn" data-fmt="${f}" onclick="setBrFmt(this,'${f}')">${f}</button>`).join('');
  // dvd sub filter
  const dvsf=g('dvd-sub-filter');
  if(type==='dvds'){dvsf.style.display='flex';document.querySelectorAll('[data-dvdsub]').forEach(b=>b.classList.remove('on'));dvsf.querySelector('[data-dvdsub="all"]').classList.add('on');}
  else dvsf.style.display='none';
  // year filter only for books/comics/dvds/music
  g('br-year').style.display=['books','comics','dvds','music'].includes(type)?'':'none';
}

function setDvdSub(btn,v){
  _dvdSub=v;
  document.querySelectorAll('[data-dvdsub]').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');renderBrGrid();
}

async function brSearch(){
  const q=g('br-search').value.trim();
  if(!q)return;
  const yr=g('br-year').value.trim();
  g('br-grid').innerHTML='<div class="browse-loading">Searching…</div>';
