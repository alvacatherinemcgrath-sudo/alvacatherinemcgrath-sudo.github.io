function logEbaySale(){
  if(!CUR_ITEM)return;
  const url=g('eb-url').value.trim(),price=parseFloat(g('eb-price').value),date=g('eb-date').value;
  const err=g('eb-err');
  if(!url||!price||price<=0||!date){err.style.display='block';setTimeout(()=>err.style.display='none',3000);return;}
  err.style.display='none';
  const wk=CUR_ITEM.key;
  if(!DB.bookSales[wk])DB.bookSales[wk]=[];
  DB.bookSales[wk].push({id:Date.now(),url,price:Math.round(price*100)/100,date});
  g('eb-url').value='';g('eb-price').value='';g('eb-date').value='';
  persist();renderEbaySales(wk);
}
function removeEbaySale(wk,id){
  if(!DB.bookSales[wk])return;
  DB.bookSales[wk]=DB.bookSales[wk].filter(s=>s.id!==id);
  persist();renderEbaySales(wk);
}
function renderEbaySales(wk){
  const sales=DB.bookSales[wk]||[];
  const list=g('eb-list');
  list.innerHTML=sales.map(s=>`<div class="es-pill">
    <span class="es-price">$${s.price.toFixed(2)}</span>
    <span class="es-date">${fmtDate(s.date)}</span>
    <span class="es-url"><a href="${x(s.url)}" target="_blank" rel="noopener">${x(s.url.replace(/^https?:\/\//,'').substring(0,36))}</a></span>
    <button class="es-del" onclick="removeEbaySale('${wk}',${s.id})">✕</button>
  </div>`).join('');
  const statsEl=g('eb-stats');
  if(sales.length<1){statsEl.innerHTML='';return;}
  const prices=sales.map(s=>s.price),n=prices.length;
  const avg=prices.reduce((a,b)=>a+b,0)/n;
  const sorted=[...prices].sort((a,b)=>a-b);
  const high=sorted[n-1],low=sorted[0];
  statsEl.innerHTML=`<div class="ebay-stats">
    <div class="est"><div class="ev">$${avg.toFixed(2)}</div><div class="el">Average</div></div>
    <div class="est g"><div class="ev">$${high.toFixed(2)}</div><div class="el">High</div></div>
    <div class="est r"><div class="ev">$${low.toFixed(2)}</div><div class="el">Low</div></div>
  </div>`;
}

