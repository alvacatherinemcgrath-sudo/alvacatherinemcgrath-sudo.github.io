async function loadEditions(key,title){
  const grid=g('editions-grid');
  grid.innerHTML='<div class="ed-loading">Loading editions…</div>';
  try{
    const r=await fetch(`https://openlibrary.org${key}/editions.json?limit=50`);
    const data=await r.json();
    CUR_EDITIONS=(data.entries||[]).map(ed=>{
      const physFmt=ed.physical_format||'';
      const fmt=classifyFmt(physFmt,_brType);
      if(fmt==='skip')return null;
      const isbn=(ed.isbn_13&&ed.isbn_13[0])||(ed.isbn_10&&ed.isbn_10[0])||'';
      const pub=(ed.publishers&&ed.publishers[0])||'';
      const yr=ed.publish_date?extractYear(ed.publish_date):null;
      const covId=ed.covers&&ed.covers[0];
      return{fmt,physFmt,isbn,pub,yr,covId,pages:ed.number_of_pages||null};
    }).filter(Boolean);
    // dedup
    const seen=new Set();
    CUR_EDITIONS=CUR_EDITIONS.filter(e=>{const k=e.isbn||(e.fmt+'|'+e.pub+'|'+e.yr);if(seen.has(k))return false;seen.add(k);return true;});
    renderEditions();
  }catch(e){grid.innerHTML='<div class="ed-none">Could not load editions.</div>';}
}

